// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "./generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Provider {
  LOCAL
  GOOGLE
  FACEBOOK
  GITHUB
}

enum Role {
  USER
  ADMIN
  CUSTOMER
}

model Account {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  provider  Provider
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User?
}

model User {
  id        String   @id @default(uuid())
  name      String
  accountId String   @unique
  role      Role     @default(USER)
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([name])
  @@index([createdAt])
}

model Menu {
  id            String   @id @default(uuid())
  name          String
  description   String?
  iconUrl       String?
  position      String
  requiredRoles Role[]   @default([USER])
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  menuItems MenuItem[]

  @@unique([name, position])
}

model MenuItem {
  id            String  @id @default(uuid())
  name          String
  menuId        String
  iconUrl       String?
  href          String?
  parentId      String?
  requiredRoles Role[]  @default([USER])
  isActive      Boolean @default(true)
  sortOrder     Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  menu     Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  parent   MenuItem?  @relation("MenuItemHierarchy", fields: [parentId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  children MenuItem[] @relation("MenuItemHierarchy")

  @@unique([menuId, name])
  @@index([name])
  @@index([parentId])
}
